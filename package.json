{
  "name": "lamprey-harness",
  "version": "0.1.43",
  "description": "Multi-agent coding harness for DeepSeek V4 Pro/Flash, Gemma, and Qwen.",
  "main": "./out/main/index.js",
  "author": {
    "name": "Lamprey Contributors",
    "url": "https://github.com/USS-Parks/lamprey"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/USS-Parks/lamprey.git"
  },
  "homepage": "https://github.com/USS-Parks/lamprey",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:bundle": "node scripts/smoke-bundle.cjs",
    "smoke:renderer": "node scripts/smoke-renderer.cjs",
    "build:win": "electron-vite build && electron-builder --win --publish never",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --publish never",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@babel/standalone": "^7.29.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "openai": "^6.39.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "sqlite-vec": "^0.1.9",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.8",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-updater": "^6.8.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "5.7",
    "vitest": "^4.1.7"
  }
}
